{
  "name": "kat-comment-studio",
  "displayName": "KAT Comment Studio",
  "description": "XML documentation comment rendering, reflow, code anchors, and link navigation for VS Code",
  "version": "1.0.10",
  "publisher": "conduent-kat-team",
  "author": {
    "name": "Terry Aney",
    "email": "terry.aney@icloud.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/terryaney/Extensibility.VS.Code.Comment.Studio"
  },
  "icon": "media/logo.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:csharp",
    "onLanguage:vb",
    "onLanguage:fsharp",
    "onLanguage:cpp",
    "onLanguage:c",
    "onLanguage:typescript",
    "onLanguage:javascript",
    "onLanguage:typescriptreact",
    "onLanguage:javascriptreact",
    "onLanguage:razor",
    "onLanguage:sql",
    "onLanguage:powershell",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kat-comment-studio",
          "title": "KAT Comment Studio",
          "icon": "$(code-oss)"
        }
      ],
      "panel": [
        {
          "id": "kat-comment-studio-panel",
          "title": "KAT Comment Studio",
          "icon": "$(code-oss)"
        }
      ]
    },
    "views": {
      "kat-comment-studio": [
        {
          "id": "kat-comment-studio.anchorsView",
          "name": "KAT Comment Studio",
		  "icon": "$(code-oss)"
        }
      ],
      "kat-comment-studio-panel": [
        {
          "type": "webview",
          "id": "kat-comment-studio.anchorsGrid",
          "name": "KAT Comment Studio - Code Anchors",
		  "icon": "$(code-oss)"
        }
      ]
    },
    "submenus": [
      {
        "id": "kat-comment-studio.submenu",
        "label": "KAT Comment Studio"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "kat-comment-studio.submenu",
          "group": "kat-comment-studio",
          "when": "editorLangId =~ /^(csharp|vb|fsharp|cpp|c|typescript|javascript|typescriptreact|javascriptreact|razor|sql|powershell)$/"
        }
      ],
      "kat-comment-studio.submenu": [
        {
          "command": "kat-comment-studio.toggleRendering",
          "group": "1_rendering@1"
        },
        {
          "command": "kat-comment-studio.reflowComment",
          "group": "2_reflow@1"
        },
        {
          "command": "kat-comment-studio.reflowAllComments",
          "group": "2_reflow@2"
        },
        {
          "command": "kat-comment-studio.removeCurrentXmlComment",
          "group": "3_remove@1"
        },
        {
          "command": "kat-comment-studio.removeXmlDocOnly",
          "group": "3_remove@2"
        }
      ],
      "view/title": [
        {
          "command": "kat-comment-studio.scanAnchors",
          "when": "view == kat-comment-studio.anchorsView",
          "group": "navigation@1"
        },
        {
          "command": "kat-comment-studio.exportAnchors",
          "when": "view == kat-comment-studio.anchorsView",
          "group": "navigation@2"
        },
        {
          "command": "kat-comment-studio.setAnchorScope",
          "when": "view == kat-comment-studio.anchorsView",
          "group": "navigation@3"
        },
        {
          "command": "kat-comment-studio.filterAnchorTypes",
          "when": "view == kat-comment-studio.anchorsView",
          "group": "navigation@4"
        },
        {
          "command": "kat-comment-studio.scanAnchors",
          "when": "view == kat-comment-studio.anchorsGrid",
          "group": "navigation@1"
        },
        {
          "command": "kat-comment-studio.exportAnchors",
          "when": "view == kat-comment-studio.anchorsGrid",
          "group": "navigation@2"
        }
      ]
    },
    "commands": [
      {
        "command": "kat-comment-studio.toggleRendering",
        "title": "Toggle Comment Rendering",
        "category": "KAT Comment Studio"
      },
      {
        "command": "kat-comment-studio.reflowComment",
        "title": "Reflow Current Comment",
        "category": "KAT Comment Studio",
        "icon": "$(wrap)",
        "enablement": "kat-comment-studio.cursorInXmlComment"
      },
      {
        "command": "kat-comment-studio.reflowAllComments",
        "title": "Reflow Comments in File",
        "category": "KAT Comment Studio",
        "icon": "$(wrap)"
      },
      {
        "command": "kat-comment-studio.showCommentTooltip",
        "title": "Show Comment Tooltip",
        "category": "KAT Comment Studio",
        "enablement": "kat-comment-studio.cursorHasAssociatedComment && kat-comment-studio.renderingActive"
      },
      {
        "command": "kat-comment-studio.scanAnchors",
        "title": "Scan Code Anchors",
        "category": "KAT Comment Studio",
        "icon": "$(refresh)"
      },
      {
        "command": "kat-comment-studio.exportAnchors",
        "title": "Export Code Anchors",
        "category": "KAT Comment Studio",
        "icon": "$(export)"
      },
      {
        "command": "kat-comment-studio.setAnchorScope",
        "title": "Set Anchor Scope",
        "category": "KAT Comment Studio",
        "icon": "$(surround-with)"
      },
      {
        "command": "kat-comment-studio.filterAnchorTypes",
        "title": "Filter Anchor Types",
        "category": "KAT Comment Studio",
        "icon": "$(list-filter)"
      },
      {
        "command": "kat-comment-studio.nextAnchor",
        "title": "Go to Next Anchor",
        "category": "KAT Comment Studio"
      },
      {
        "command": "kat-comment-studio.previousAnchor",
        "title": "Go to Previous Anchor",
        "category": "KAT Comment Studio"
      },
      {
        "command": "kat-comment-studio.removeCurrentXmlComment",
        "title": "Remove Current XML Comment",
        "category": "KAT Comment Studio",
        "enablement": "kat-comment-studio.cursorInXmlComment"
      },
      {
        "command": "kat-comment-studio.removeXmlDocOnly",
        "title": "Remove All XML Comments in File",
        "category": "KAT Comment Studio"
      }
    ],
    "keybindings": [
      {
        "command": "kat-comment-studio.showCommentTooltip",
        "key": "F1",
        "when": "editorTextFocus && kat-comment-studio.interceptF1Active"
      }
    ],
    "keybindings.off": [
      {
        "command": "kat-comment-studio.toggleRendering",
        "key": "escape",
        "when": "editorTextFocus && kat-comment-studio.renderingActive"
      },
      {
        "command": "kat-comment-studio.nextAnchor",
        "key": "alt+pagedown",
        "when": "editorTextFocus"
      },
      {
        "command": "kat-comment-studio.previousAnchor",
        "key": "alt+pageup",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "KAT Comment Studio",
      "properties": {
        "kat-comment-studio.xmlCommentRendering": {
          "type": "boolean",
          "default": true,
          "description": "Enable XML Comment Rendering (CodeLens summary, auto-fold, and apply Comment Opacity).",
		  "order": 0
        },
        "kat-comment-studio.xmlCommentOpacity": {
          "type": "integer",
          "default": 40,
          "minimum": 0,
          "maximum": 100,
          "description": "When XML Comment Rendering is enabled, specify the opacity percentage (0-100) for dimmed original comments. 0 = fully invisible; 100 = no dimming.",
		  "order": 2
        },
        "kat-comment-studio.codeLensSummaryTruncation": {
          "type": "number",
          "default": 205,
          "minimum": 0,
          "maximum": 500,
          "description": "Maximum number of characters for the CodeLens summary text before truncation. Set to 0 for no truncation.",
		  "order": 1
        },
        "kat-comment-studio.reflowLineLength": {
          "type": "number",
          "default": 120,
          "minimum": 40,
          "maximum": 500,
          "description": "Maximum line width for comment reflow. Can be overridden by .editorconfig max_line_length.",
		  "order": 3
        },
        "kat-comment-studio.enableReflowOnCommentExit": {
          "type": "boolean",
          "default": true,
          "description": "Automatically reflow a XML comment block after editing when the cursor leaves the block.",
		  "order": 4
        },
        "kat-comment-studio.enableReflowOnPaste": {
          "type": "boolean",
          "default": true,
          "description": "Automatically reflow XML comment blocks when pasting text into the block.",
		  "order": 5
        },
        "kat-comment-studio.interceptF1ForComments": {
          "type": "boolean",
          "default": true,
          "description": "When the cursor is inside XML comment block, or method that has XML comments, pressing F1 shows the KAT Comment Studio tooltip instead of the VS Code help menu. Disable to restore the default F1 behavior.",
		  "order": 6
        },
        "kat-comment-studio.collapseXmlWhenRenderingOff": {
          "type": "boolean",
          "default": false,
          "description": "Automatically collapse XML comments when opening files when rendering is Off.  When rendering is toggled On, comments automatically collapse/expand based on cursor position.",
		  "order": 7
        },

		"kat-comment-studio.anchorColorizeMode": {
          "type": "string",
          "enum": [
            "never",
            "fullAnchor",
            "caseSensitive",
            "caseInsensitive"
          ],
          "default": "caseInsensitive",
          "enumDescriptions": [
            "Disable all anchor keyword colorization",
            "Only colorize when followed by ':' (e.g. 'TODO:') or a metadata block (e.g. 'TODO(owner):')",
            "Colorize with or without ':', only when the keyword case exactly matches the tag definition",
            "Colorize with or without ':', regardless of case (default behavior)"
          ],
          "description": "Controls inline colorization of anchor keywords in editor comments. ANCHOR without '(name):' is never colorized regardless of this setting.",
		  "order": 8
        },
        "kat-comment-studio.colorOverrides": {
          "type": "object",
          "default": {},
          "additionalProperties": {
            "type": "string"
          },
          "markdownDescription": "Override colors for anchor tags and UI elements. Map a key to a hex color string (e.g. `\"todo\": \"#FFA500\"`). Omitted keys fall back to theme defaults.\n\n**Rendered comment keys:** `renderedText`, `renderedHeading`, `renderedCode`, `renderedLink`\n\n**Anchor type keys:** `todo`, `hack`, `note`, `bug`, `fixme`, `undone`, `review`, `anchor`, `custom`\n\n**Prefix highlight keys:** `prefixAlert`, `prefixQuestion`, `prefixHighlight`, `prefixStrikethrough`, `prefixDisabled`, `prefixQuote`",
		  "order": 9
        },
        "kat-comment-studio.enableIssueLinks": {
          "type": "boolean",
          "default": true,
          "description": "Enable clickable issue links (#123 \u2192 GitHub/GitLab/etc.)",
		  "order": 10
        },
        "kat-comment-studio.enablePrefixHighlighting": {
          "type": "boolean",
          "default": true,
          "description": "Enable 'Better Comments'-style prefix highlighting (! ? * // - >)",
		  "order": 11
        },
        "kat-comment-studio.patternProcessing": {
          "type": "object",
          "default": {
            "customTags": "",
            "enabledLanguages": "csharp, vb, fsharp, cpp, c, typescript, javascript, typescriptreact, javascriptreact, razor, sql, powershell",
            "fileExtensions": "cs, vb, fs, cpp, c, h, ts, tsx, js, jsx, razor, cshtml, sql, ps1, psm1",
            "ignoreFolders": "node_modules, bin, obj, .git, dist, out, build, .vs, .vscode-test",
            "tagPrefixes": "@, $"
          },
          "additionalProperties": {
            "type": "string"
          },
          "markdownDescription": "Controls which files, folders, languages, and tags are processed. Values are comma-separated strings (like `files.associations`). Only override keys you want to change.\n\n| Key | Description |\n|---|---|\n| `customTags` | Custom anchor tags highlighted in Goldenrod and shown in Code Anchors tree |\n| `enabledLanguages` | VS Code language IDs for which rendering and anchors are active |\n| `fileExtensions` | File extensions included in anchor scan and LINK: validation |\n| `ignoreFolders` | Folder names excluded from anchor scan |\n| `tagPrefixes` | Prefix characters recognised before anchor tags — `@TODO` is treated as `TODO` |",
		  "order": 12
        },
        "kat-comment-studio.scanOnLoad": {
          "type": "boolean",
          "default": true,
          "description": "Automatically scan workspace for code anchors on activation",
		  "order": 13
        },
        "kat-comment-studio.showAnchorCountBadges": {
          "type": "boolean",
          "default": true,
          "description": "Show a count badge on the sidebar icon and highlight the status bar yellow until the Code Anchors pane is viewed. Disable to suppress both the badge and the yellow highlight.",
		  "order": 14
        }
      }
    },
    "colors": [
      {
        "id": "katCommentStudio.anchorCountForeground",
        "description": "Foreground color of the anchor count status bar item when anchors are present and unviewed. Defaults to the active panel title color.",
        "defaults": {
          "dark": "panelTitle.activeForeground",
          "light": "panelTitle.activeForeground",
          "highContrast": "panelTitle.activeForeground"
        }
      },
      {
        "id": "katCommentStudio.anchorTodo",
        "description": "TODO anchor color",
        "defaults": {
          "dark": "#FF8C00",
          "light": "#CC7000",
          "highContrast": "#FFB347"
        }
      },
      {
        "id": "katCommentStudio.anchorHack",
        "description": "HACK anchor color",
        "defaults": {
          "dark": "#DC143C",
          "light": "#B01030",
          "highContrast": "#FF4060"
        }
      },
      {
        "id": "katCommentStudio.anchorNote",
        "description": "NOTE anchor color",
        "defaults": {
          "dark": "#4169E1",
          "light": "#3050B0",
          "highContrast": "#6090FF"
        }
      },
      {
        "id": "katCommentStudio.anchorBug",
        "description": "BUG anchor color",
        "defaults": {
          "dark": "#FF0000",
          "light": "#CC0000",
          "highContrast": "#FF4040"
        }
      },
      {
        "id": "katCommentStudio.anchorFixme",
        "description": "FIXME anchor color",
        "defaults": {
          "dark": "#FF4500",
          "light": "#CC3800",
          "highContrast": "#FF6530"
        }
      },
      {
        "id": "katCommentStudio.anchorUndone",
        "description": "UNDONE anchor color",
        "defaults": {
          "dark": "#808080",
          "light": "#606060",
          "highContrast": "#A0A0A0"
        }
      },
      {
        "id": "katCommentStudio.anchorReview",
        "description": "REVIEW anchor color",
        "defaults": {
          "dark": "#9370DB",
          "light": "#7050B0",
          "highContrast": "#B090FF"
        }
      },
      {
        "id": "katCommentStudio.anchorAnchor",
        "description": "ANCHOR anchor color",
        "defaults": {
          "dark": "#20B2AA",
          "light": "#108880",
          "highContrast": "#40D0C8"
        }
      },
      {
        "id": "katCommentStudio.anchorCustom",
        "description": "Custom anchor tag color",
        "defaults": {
          "dark": "#DAA520",
          "light": "#B8860B",
          "highContrast": "#FFD700"
        }
      },
      {
        "id": "katCommentStudio.renderedText",
        "description": "Rendered comment text color",
        "defaults": {
          "dark": "#D4D4D4",
          "light": "#333333",
          "highContrast": "#FFFFFF"
        }
      },
      {
        "id": "katCommentStudio.renderedHeading",
        "description": "Rendered comment heading color",
        "defaults": {
          "dark": "#569CD6",
          "light": "#0000FF",
          "highContrast": "#6090FF"
        }
      },
      {
        "id": "katCommentStudio.renderedCode",
        "description": "Rendered inline code color",
        "defaults": {
          "dark": "#CE9178",
          "light": "#A31515",
          "highContrast": "#FFB090"
        }
      },
      {
        "id": "katCommentStudio.renderedLink",
        "description": "Rendered link color",
        "defaults": {
          "dark": "#3794FF",
          "light": "#006AB1",
          "highContrast": "#3794FF"
        }
      },
      {
        "id": "katCommentStudio.parameterName",
        "description": "Parameter name color in rendered XML doc comments",
        "defaults": {
          "dark": "#7BD88F",
          "light": "#7BD88F",
          "highContrast": "#7BD88F"
        }
      },
      {
        "id": "katCommentStudio.typeName",
        "description": "Type/class name color in rendered XML doc comments",
        "defaults": {
          "dark": "#5AD4E6",
          "light": "#5AD4E6",
          "highContrast": "#5AD4E6"
        }
      },
      {
        "id": "katCommentStudio.prefixAlert",
        "description": "Alert prefix (!) comment color",
        "defaults": {
          "dark": "#FF2D00",
          "light": "#CC0000",
          "highContrast": "#FF4040"
        }
      },
      {
        "id": "katCommentStudio.prefixQuestion",
        "description": "Question prefix (?) comment color",
        "defaults": {
          "dark": "#3498DB",
          "light": "#2070B0",
          "highContrast": "#60A0FF"
        }
      },
      {
        "id": "katCommentStudio.prefixHighlight",
        "description": "Highlight prefix (*) comment color",
        "defaults": {
          "dark": "#98C379",
          "light": "#008000",
          "highContrast": "#80FF80"
        }
      },
      {
        "id": "katCommentStudio.prefixStrikethrough",
        "description": "Strikethrough prefix (//) comment color",
        "defaults": {
          "dark": "#808080",
          "light": "#999999",
          "highContrast": "#A0A0A0"
        }
      },
      {
        "id": "katCommentStudio.prefixDisabled",
        "description": "Disabled prefix (-) comment color",
        "defaults": {
          "dark": "#505050",
          "light": "#AAAAAA",
          "highContrast": "#707070"
        }
      },
      {
        "id": "katCommentStudio.prefixQuote",
        "description": "Quote prefix (>) comment color",
        "defaults": {
          "dark": "#C586C0",
          "light": "#800080",
          "highContrast": "#D070D0"
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/release.ps1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45"
  }
}
